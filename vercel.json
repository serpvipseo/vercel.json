{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "frame-ancestors 'self' https://*.blogspot.com https://serpvip.blogspot.com https://serpvip.blogspot.com/*"
        },
        {
          "key": "X-Frame-Options",
          "value": "ALLOW-FROM https://serpvip.blogspot.com/"
        }
      ]
    }
  ]
}
